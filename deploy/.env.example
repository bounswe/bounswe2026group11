# Fill in and copy to `deploy/.env` for `docker compose -f deploy/docker-compose.*.yml`.
# `RESEND_CLIENT_API_KEY` must be a real key when `mail_provider=resend`.
# `SPACES_*` values configure direct image uploads to DigitalOcean Spaces.
# `SPACES_CDN_BASE_URL` is the public read base URL returned to clients and stored in the database.
# `NEW_RELIC_LICENSE_KEY` is only for dev and prod environments.
DOCKERHUB_NAMESPACE=
IMAGE_TAG=latest
DB_PASSWORD=
JWT_SECRET=
# Browser CORS origins for backend API. Origins do not include paths.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,http://127.0.0.1:8081,exp://localhost:8081,https://socialeventmapper.com,https://www.socialeventmapper.com,https://*.socialeventmapper.com
MAX_REQUEST_BODY_BYTES=4194304
RESEND_CLIENT_API_KEY=
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
SPACES_ENDPOINT=
SPACES_BUCKET=
SPACES_CDN_BASE_URL=
SPACES_S3_REGION=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# Alternatively mount a credentials file in the backend container and set:
# FIREBASE_CREDENTIALS_FILE=
NEW_RELIC_LICENSE_KEY=
VITE_GOOGLE_MAPS_WEB_API_KEY=
