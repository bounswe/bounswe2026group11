# Optional: copy to `.env` in the repository root when using
# `docker compose -f deploy/docker-compose.local.yml` (or `deploy/docker-compose.dev.yml`) from the repo root.
# Docker Compose substitutes these into the compose file (see Compose variable substitution).
# Do not commit `.env` — it is gitignored.

DB_PASSWORD=postgres
JWT_SECRET=dev-only-change-for-production

# Non-secret values are kept in versioned files:
# - Postgres user/database in `deploy/docker-compose*.yml`
# - Backend runtime settings in `backend/config/application.*.yaml`
# For `deploy/docker-compose.dev.yml`, provide `DOCKERHUB_NAMESPACE` via shell/CI instead of `.env`.
